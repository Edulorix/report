    html:/html|웹|페이지|코드|복사 후 수정|업무 도구|현황판/.test(t),
    scheduler:/스케줄러|일정|타임라인|d-day|마감|달력/.test(t),
    dashboard:/대시보드|현황판|운영 현황|교육 운영/.test(t),
    project:/프로젝트|발표|최종|산출물|개인 업무/.test(t),
    easy:/쉽게|어렵지|초보|비개발자|용어|난이도|따라/.test(t),
    msOnly:/ms|copilot|코파일럿|외부 ai|chatgpt|claude|클로드|제외|사용하지/.test(t),
    role:/강사|담당|파트|분배|역할|a는|b는|c는|d는/.test(t),
    risk:/리스크|우려|이슈|문제|난이도|중복|부담|편차|이탈|어렵/.test(t)
  };
}

function categorizeNotes(raw){
  const lines = smartLines(raw).map(refineSentence).filter(Boolean);

  const out = {
    direction:[],
    conditions:[],
    toc:[],
    practice:[],
    roles:[],
    risks:[],
    next:[],
    memo:[]
  };

  for(const line of lines){
    if(/목표|방향|중심|역량|실무|대상|수준|학습|과정/.test(line)) out.direction.push(line);
    else if(/MS Copilot|외부 AI|제외|지양|고정|반드시|필수|사용하지|중심/.test(line)) out.conditions.push(line);
    else if(/목차|커리큘럼|회차|모듈|기본기|문서|메일|회의록|프롬프트|교재/.test(line)) out.toc.push(line);
    else if(/실습|To-do|스케줄러|현황판|HTML|웹|산출물|페이지|프로젝트|대시보드/.test(line)) out.practice.push(line);
    else if(/강사|담당|파트|역할|분배|A는|B는|C는|D는/.test(line)) out.roles.push(line);
    else if(/리스크|우려|문제|중복|난이도|부담|편차|이탈|과도|어렵/.test(line)) out.risks.push(line);
    else if(/다음|차기|준비|정리|확정|검토|작성|공유|미팅/.test(line)) out.next.push(line);
    else out.memo.push(line);
  }

  Object.keys(out).forEach(k=>out[k]=uniq(out[k]));
  return out;
}

