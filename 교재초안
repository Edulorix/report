    "최종 프로젝트를 통해 개인 업무 개선 결과물을 완성한다.",
    ...notes.direction
  ]);

  const risks = uniq([
    ...notes.risks,
    flags.easy ? "수강생별 AI/HTML 활용 수준 차이로 인해 실습 난이도 편차가 발생할 수 있음" : "",
    flags.html ? "HTML 실습이 개발 교육으로 오해되지 않도록 업무 도구 제작 관점으로 설명 필요" : "",
    flags.msOnly ? "외부 AI 도구와 혼재되지 않도록 교재 표현과 실습 도구 기준을 명확히 해야 함" : "",
    "회차별 실습 산출물이 많아질 경우 시간 내 완성도 관리가 필요함"
  ].filter(Boolean));

  const next = uniq([
    ...notes.next,
    "차기 미팅에서 회차별 목차, 교재 템플릿, 강사별 담당 범위를 확정",
