  return {principles,goals,risks,next};
}

function renderSignal(title,text,type){
  return `
    <div class="signal ${type}">
      <div class="signal-title">${esc(title)}</div>
      <div class="signal-text">${esc(text || "해당 사항 없음")}</div>
    </div>
  `;
}

function renderList(items,empty){
  if(!items.length){
    return `<div class="signal-list">${renderSignal("NO DATA",empty,"warn")}</div>`;
  }

  return `
    <ul class="list">
      ${items.map((item,i)=>`
        <li class="list-item">
          <div class="list-no">${i+1}</div>
          <div class="list-body">${esc(item)}</div>
        </li>
      `).join("")}
    </ul>
  `;
}

function buildSummaryText(curriculum,insights){
  const lines = [];

  lines.push(`[프로젝트] ${PROJECT_TITLE}`);
  lines.push(`[과정 규모] ${COURSE_SCALE.label}`);
  lines.push(`[활용 도구] ${MAIN_TOOL}`);
  lines.push("");
  lines.push("[교재 개발 방향]");
  lines.push("MS Copilot 기반 프롬프트 작성 역량 강화와 업무 산출물 제작 중심의 실습형 중급 과정");
  lines.push("");
  lines.push("[교재 구성 원칙]");
  insights.principles.forEach(v=>lines.push(`- ${v}`));
  lines.push("");
  lines.push("[회차별 목차안]");
  curriculum.forEach((c,i)=>{
    lines.push(`${i+1}. ${c.title}`);
    lines.push(`   - 학습 목표: ${c.objective}`);
    lines.push(`   - 실습: ${c.practice}`);
    lines.push(`   - 산출물: ${c.output}`);
  });
  lines.push("");
  lines.push("[다음 개발 액션]");
  insights.next.slice(0,6).forEach(v=>lines.push(`- ${v}`));

  return lines.join("\n");
}

