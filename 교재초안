function loadDraft(){
  const raw = localStorage.getItem(STORAGE_DRAFT);

  if(!raw){
    toast("저장된 최근 초안이 없습니다.","warn");
    return;
  }

  $("memoInput").value = raw;
  toast("최근 초안을 불러왔습니다.","good");
}

function loadLastReport(){
  try{
    const data = JSON.parse(localStorage.getItem(STORAGE_REPORT) || "null");
    if(!data || !data.html) return;

    $("reportMount").className = "";
    $("reportMount").innerHTML = data.html;
    lastReport = data;
  }catch(e){}
}

$("btnGenerate").addEventListener("click",buildAll);
$("btnSample").addEventListener("click",loadSample);
$("btnSampleTop").addEventListener("click",loadSample);

$("btnClear").addEventListener("click",()=>{
  if(!confirm("자유 메모를 초기화할까요?")) return;
  $("memoInput").value = "";
  localStorage.removeItem(STORAGE_DRAFT);
  toast("초기화 완료","good");
});

$("btnSaveDraft").addEventListener("click",()=>{
  localStorage.setItem(STORAGE_DRAFT,$("memoInput").value);
  toast("초안 저장 완료","good");
});

$("btnLoadDraft").addEventListener("click",loadDraft);

$("btnPrint").addEventListener("click",()=>{
  if(!lastReport && !$("reportMount").querySelector(".doc")){
    toast("먼저 교재 개요·목차안을 생성해주세요.","warn");
    return;
  }

  window.print();
});

$("btnCopySummary").addEventListener("click",async()=>{
  if(!lastReport){
    toast("먼저 교재 개요·목차안을 생성해주세요.","warn");
    return;
  }

  try{
    await navigator.clipboard.writeText(lastReport.summaryText);
    toast("요약 복사 완료","good");
  }catch(e){
    toast("복사에 실패했습니다.","bad");
  }
});

$("btnCopyHTML").addEventListener("click",async()=>{
  const html = $("reportMount").innerHTML.trim();

  if(!html || !$("reportMount").querySelector(".doc")){
    toast("먼저 교재 개요·목차안을 생성해주세요.","warn");
    return;
  }

  try{
    await navigator.clipboard.writeText(html);
    toast("HTML 복사 완료","good");
  }catch(e){
    toast("복사에 실패했습니다.","bad");
  }
});

(function init(){
  const saved = localStorage.getItem(STORAGE_DRAFT);

  if(saved){
    $("memoInput").value = saved;
  }

  loadLastReport();
})();
</script>
