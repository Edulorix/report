function esc(value){
  if(value == null) return "";
  return String(value)
    .replace(/&/g,"&amp;")
    .replace(/</g,"&lt;")
    .replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;")
    .replace(/'/g,"&#39;");
}

function todayStr(){
  const d = new Date();
  const p = n => String(n).padStart(2,"0");
  return `${d.getFullYear()}.${p(d.getMonth()+1)}.${p(d.getDate())}`;
}

function toast(msg,type="default"){
  const wrap = $("toastWrap");
  const el = document.createElement("div");
  el.className = `toast ${type==="good"?"good":type==="warn"?"warn":type==="bad"?"bad":""}`;
  el.textContent = msg;
  wrap.appendChild(el);
  setTimeout(()=>{
    el.style.opacity = "0";
    el.style.transform = "translateY(-6px)";
    el.style.transition = ".2s ease";
    setTimeout(()=>el.remove(),220);
  },2400);
}

function stripBullet(s){
  return String(s || "").replace(/^\s*[-•·▪◦▸►→]+\s*/,"").trim();
}

function smartLines(raw){
  return String(raw || "")
    .replace(/\r/g,"")
    .replace(/[•·▪◦▸►→]/g,"-")
    .split("\n")
    .map(v=>v.trim())
    .filter(Boolean);
}

function normalizeKey(s){
  return String(s || "")
    .replace(/\s+/g," ")
    .replace(/[.,:;·•\-—()（）[\]【】]/g,"")
    .trim()
    .toLowerCase();
}

function uniq(arr){
  const out = [];
  const seen = new Set();
  for(const item of arr){
    const key = normalizeKey(item);
    if(!key || seen.has(key)) continue;
    seen.add(key);
    out.push(item);
  }
  return out;
}

function refineSentence(text){
  let s = String(text || "").trim();
  if(!s) return "";

  s = stripBullet(s)
    .replace(/\s+/g," ")
    .replace(/그냥\s*/g,"")
    .replace(/약간\s*/g,"")
    .replace(/일단\s*/g,"")
    .replace(/뭔가\s*/g,"")
    .replace(/좀\s*/g,"")
    .replace(/아무튼\s*/g,"")
    .replace(/개발새발/g,"정리되지 않은 메모")
    .replace(/대충/g,"초안 수준으로")
    .replace(/복붙/g,"복사 후 수정")
    .replace(/써먹/g,"활용")
    .replace(/했음/g,"하였음")
    .replace(/할거임/g,"진행 예정")
    .replace(/갈거임/g,"추진 예정")
    .replace(/해야 함/g,"필요")
    .replace(/해야함/g,"필요")
    .replace(/넣어야 함/g,"포함 필요")
    .replace(/넣어야함/g,"포함 필요")
    .replace(/넣자/g,"포함")
    .replace(/빼야 함/g,"제외 필요")
    .replace(/빼야함/g,"제외 필요")
    .replace(/하지 말자/g,"지양")
    .replace(/어렵게 하지 말자/g,"난이도 조정 필요")
    .replace(/너무 어려운/g,"고난이도")
    .replace(/너무/g,"과도하게")
    .replace(/괜찮음/g,"적합")
    .replace(/좋을 듯/g,"검토 가능")
    .replace(/하면 좋겠음/g,"검토 필요")
    .replace(/공유함/g,"공유 완료")
    .replace(/공유했음/g,"공유 완료")
    .replace(/얘기/g,"논의")
    .replace(/니까/g,"므로")
    .replace(/니깐/g,"므로")
    .replace(/해서/g,"하여")
    .replace(/같음/g,"것으로 판단됨")
    .replace(/보임/g,"것으로 판단됨")
    .replace(/처음부터 코딩/g,"전체 코드를 직접 작성")
    .replace(/AI 도움/g,"Copilot 도움");

  if(/chatgpt|claude|클로드|openai|외부 ai/i.test(s)){
    s = s.replace(/chatgpt|claude|클로드|openai/gi,"외부 AI 도구");
    if(!/제외|지양|사용하지 않/.test(s)){
      s += "는 본 과정 범위에서 제외";
    }
  }

  return s.replace(/\s{2,}/g," ").trim();
}

function detectFlags(raw){
  const t = raw.toLowerCase();

  return {
    prompt:/프롬프트|prompt|질문|요청|지시|좋은 질문|요청문/.test(t),
