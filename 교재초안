<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI 활용 역량 강화 중급 과정 개발 프로젝트 — 교재 개요·목차 자동 생성기</title>

<style>
:root{
  --bg:#f3f6fb;
  --paper:#ffffff;
  --text:#111827;
  --text2:#334155;
  --text3:#475569;
  --muted:#64748b;
  --line:#dbe3ec;
  --navy:#0f172a;
  --blue:#1d4ed8;
  --indigo:#4f46e5;
  --green:#047857;
  --amber:#b45309;
  --red:#b91c1c;
  --shadow:0 16px 40px rgba(15,23,42,.09);
  --shadow2:0 6px 18px rgba(15,23,42,.06);
  --font:"Malgun Gothic","맑은 고딕",Arial,sans-serif;
}

*{box-sizing:border-box}

html,body{
  margin:0;
  padding:0;
}

body{
  min-height:100vh;
  font-family:var(--font);
  color:var(--text);
  background:
    radial-gradient(circle at 0% 0%,rgba(37,99,235,.08),transparent 28%),
    radial-gradient(circle at 100% 0%,rgba(79,70,229,.07),transparent 24%),
    linear-gradient(180deg,#f8fbff 0%,#f3f6fb 100%);
}

button,textarea{
  font-family:var(--font);
}

.app{
  max-width:1560px;
  margin:0 auto;
  padding:28px;
}

.header{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  gap:24px;
  margin-bottom:24px;
}

.header-left{
  max-width:1040px;
}

.badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:8px 13px;
  border-radius:999px;
  background:#eef2ff;
  border:1px solid #dbeafe;
  color:#3730a3;
  font-size:12px;
  font-weight:900;
  letter-spacing:.04em;
}

.badge-dot{
  width:8px;
  height:8px;
  border-radius:50%;
  background:linear-gradient(135deg,#1d4ed8,#4f46e5);
}

.header h1{
  margin:14px 0 8px;
  font-size:34px;
  line-height:1.18;
  letter-spacing:-.04em;
  word-break:keep-all;
}

.header p{
  margin:0;
  color:var(--muted);
  font-size:14px;
  line-height:1.85;
  word-break:keep-all;
}

.header-actions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  justify-content:flex-end;
}

.layout{
  display:grid;
  grid-template-columns:480px 1fr;
  gap:22px;
  align-items:start;
}

@media(max-width:1280px){
  .header{
    flex-direction:column;
    align-items:flex-start;
  }

  .header-actions{
    justify-content:flex-start;
  }

  .layout{
    grid-template-columns:1fr;
  }
}

.panel{
  background:rgba(255,255,255,.92);
  border:1px solid rgba(255,255,255,.9);
  border-radius:28px;
  box-shadow:var(--shadow);
  overflow:hidden;
}

.panel-head{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:flex-start;
  padding:22px 24px 18px;
  border-bottom:1px solid var(--line);
  background:linear-gradient(180deg,#ffffff,#f9fbff);
}

.panel-head h2{
  margin:0;
  font-size:19px;
  letter-spacing:-.02em;
}

.panel-head p{
  margin:6px 0 0;
  color:var(--muted);
  font-size:13px;
  line-height:1.75;
}

.panel-body{
  padding:22px 24px 24px;
}

.memo-box{
  width:100%;
  min-height:560px;
  resize:vertical;
  border:1px solid var(--line);
  border-radius:18px;
  background:#fff;
  padding:16px 17px;
  color:var(--text);
  font-size:14px;
  line-height:1.85;
  outline:none;
}

.memo-box:focus{
  border-color:#93c5fd;
  box-shadow:0 0 0 4px rgba(37,99,235,.12);
}

.memo-box::placeholder{
  color:#94a3b8;
}

.tip{
  margin-top:12px;
  padding:15px 16px;
  border:1px solid var(--line);
  border-radius:18px;
  background:linear-gradient(180deg,#ffffff,#f9fbff);
}

.tip strong{
  display:block;
  margin-bottom:7px;
  color:var(--text2);
  font-size:13px;
}

.tip ul{
  margin:0 0 0 18px;
  padding:0;
  color:var(--muted);
  font-size:12px;
  line-height:1.9;
}

.actions{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  flex-wrap:wrap;
  margin-top:20px;
  padding-top:18px;
  border-top:1px dashed var(--line);
}

.btn-row,
.toolbar{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

.btn{
  border:none;
  border-radius:14px;
  padding:12px 16px;
  font-size:14px;
  font-weight:900;
  cursor:pointer;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  transition:.18s ease;
  white-space:nowrap;
}

.btn:hover{
  transform:translateY(-1px);
}

.btn.primary{
  color:#fff;
  background:linear-gradient(135deg,#0f172a,#1e3a8a);
  box-shadow:0 10px 24px rgba(15,23,42,.18);
}

.btn.sub{
  color:var(--text);
  background:#fff;
  border:1px solid var(--line);
}

.btn.ghost{
  color:var(--muted);
  background:transparent;
  border:1px dashed var(--line);
}

.preview-wrap{
  padding:22px;
  background:linear-gradient(180deg,rgba(255,255,255,.9),rgba(255,255,255,.98));
}

.empty{
  min-height:1020px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  border:1px dashed var(--line);
  border-radius:28px;
  background:#fff;
  color:var(--muted);
}

.empty-inner{
  max-width:650px;
  padding:34px 22px;
}

.empty h3{
  margin:0 0 10px;
  color:var(--text);
  font-size:24px;
  letter-spacing:-.03em;
}

.empty p{
  margin:0;
  font-size:14px;
  line-height:1.9;
}

.doc{
  background:#fff;
  border:1px solid var(--line);
  border-radius:30px;
  overflow:hidden;
  box-shadow:var(--shadow);
}

.doc-cover{
  position:relative;
  padding:40px 38px 34px;
  color:#fff;
  background:linear-gradient(135deg,#0f172a 0%,#132554 45%,#1e3a8a 100%);
  overflow:hidden;
}

.doc-cover::before{
  content:"";
  position:absolute;
  right:-90px;
  top:-90px;
  width:320px;
  height:320px;
  border-radius:50%;
  background:radial-gradient(circle,rgba(255,255,255,.16),transparent 70%);
}

.doc-cover::after{
  content:"";
  position:absolute;
  left:-80px;
  bottom:-100px;
  width:300px;
  height:300px;
  border-radius:50%;
  background:radial-gradient(circle,rgba(96,165,250,.24),transparent 72%);
}

.doc-cover > *{
  position:relative;
  z-index:1;
}

.doc-type{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:8px 12px;
  border-radius:999px;
  background:rgba(255,255,255,.09);
  border:1px solid rgba(255,255,255,.14);
  color:#dbeafe;
  font-size:12px;
  font-weight:900;
  letter-spacing:.05em;
  margin-bottom:18px;
}

.doc-title{
  margin:0 0 12px;
  font-size:32px;
  line-height:1.25;
  letter-spacing:-.04em;
  max-width:1080px;
  word-break:keep-all;
}

.doc-sub{
  margin:0 0 22px;
  max-width:1040px;
  color:rgba(255,255,255,.9);
  font-size:14px;
  line-height:1.9;
}

.meta{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:12px;
}

@media(max-width:980px){
  .meta{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

.meta-box{
  min-height:90px;
  padding:14px 16px;
  border-radius:18px;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.13);
}

.meta-label{
  margin-bottom:8px;
  color:rgba(255,255,255,.68);
  font-size:11px;
  font-weight:900;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.meta-value{
  color:#fff;
  font-size:14px;
  line-height:1.7;
  font-weight:700;
  word-break:keep-all;
}

.doc-body{
  padding:30px 32px 34px;
  background:linear-gradient(180deg,#ffffff 0%,#fcfdff 100%);
}

.summary-zone{
  display:grid;
  grid-template-columns:1.25fr .85fr;
  gap:16px;
  margin-bottom:18px;
}

@media(max-width:1120px){
  .summary-zone{
    grid-template-columns:1fr;
  }
}

.main-summary,
.side-box,
.section-box,
.metric,
.toc-card,
.output-card{
  background:#fff;
  border:1px solid var(--line);
  border-radius:24px;
  box-shadow:var(--shadow2);
}

.main-summary{
  padding:24px 24px 20px;
  background:linear-gradient(180deg,#ffffff,#fbfdff);
}

.eyebrow{
  margin-bottom:10px;
  color:var(--blue);
  font-size:12px;
  font-weight:900;
  letter-spacing:.06em;
}

.main-summary h2{
  margin:0 0 12px;
  font-size:23px;
  line-height:1.42;
  letter-spacing:-.03em;
  word-break:keep-all;
}

.main-summary p{
  margin:0;
  color:var(--text2);
  font-size:14px;
  line-height:1.92;
  white-space:pre-wrap;
}

.side-stack{
  display:grid;
  gap:16px;
}

.side-box{
  padding:18px;
}

.side-box h4{
  margin:0 0 10px;
  font-size:15px;
}

.signal-list{
  display:grid;
  gap:10px;
}

.signal{
  padding:14px;
  border-radius:17px;
  border:1px solid var(--line);
  background:linear-gradient(180deg,#ffffff,#fbfdff);
}

.signal.good{
  border-color:#ccefdc;
  background:linear-gradient(180deg,#f4fdf8,#ffffff);
}

.signal.info{
  border-color:#bfdbfe;
  background:linear-gradient(180deg,#eff6ff,#ffffff);
}

.signal.warn{
  border-color:#fde7b0;
  background:linear-gradient(180deg,#fffaf0,#ffffff);
}

.signal.risk{
  border-color:#fecaca;
  background:linear-gradient(180deg,#fff5f5,#ffffff);
}

.signal-title{
  margin-bottom:7px;
  font-size:12px;
  font-weight:900;
  letter-spacing:.05em;
}

.signal.good .signal-title{color:var(--green)}
.signal.info .signal-title{color:var(--blue)}
.signal.warn .signal-title{color:var(--amber)}
.signal.risk .signal-title{color:var(--red)}

.signal-text{
  color:var(--text2);
  font-size:14px;
  line-height:1.88;
  font-weight:700;
  word-break:keep-all;
  white-space:pre-wrap;
}

.metric-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:14px;
  margin-bottom:18px;
}

@media(max-width:980px){
  .metric-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

.metric{
  padding:17px;
  background:linear-gradient(180deg,#ffffff,#fbfdff);
}

.metric-label{
  margin-bottom:9px;
  color:var(--muted);
  font-size:12px;
  font-weight:800;
}

.metric-value{
  margin-bottom:8px;
  color:var(--text);
  font-size:30px;
  font-weight:900;
  letter-spacing:-.04em;
}

.metric-sub{
  color:var(--text3);
  font-size:12px;
  line-height:1.7;
}

.section{
  margin-top:22px;
}

.section-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:14px;
  margin-bottom:12px;
  flex-wrap:wrap;
}

.section-head h3{
  margin:0;
  font-size:19px;
  letter-spacing:-.02em;
}

.section-tag{
  display:inline-flex;
  align-items:center;
  padding:7px 12px;
  border-radius:999px;
  background:#f8fafc;
  border:1px solid var(--line);
  color:var(--text3);
  font-size:12px;
  font-weight:900;
}

.section-box{
  padding:18px;
}

.columns{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
}

@media(max-width:980px){
  .columns{
    grid-template-columns:1fr;
  }
}

.list{
  list-style:none;
  margin:0;
  padding:0;
  display:grid;
  gap:10px;
}

.list-item{
  display:grid;
  grid-template-columns:30px 1fr;
  gap:12px;
  padding:14px;
  border:1px solid var(--line);
  border-radius:17px;
  background:linear-gradient(180deg,#ffffff,#fbfdff);
}

.list-no{
  width:30px;
  height:30px;
  border-radius:11px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#1e3a8a,#4f46e5);
  color:#fff;
  font-size:12px;
  font-weight:900;
}

.list-body{
  color:var(--text2);
  font-size:14px;
  line-height:1.9;
  font-weight:700;
  word-break:keep-all;
}

.toc-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:14px;
}

@media(max-width:980px){
  .toc-grid{
    grid-template-columns:1fr;
  }
}

.toc-card{
  overflow:hidden;
}

.toc-head{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:12px;
  padding:17px 17px 13px;
  border-bottom:1px solid var(--line);
  background:linear-gradient(180deg,#ffffff,#fbfdff);
}

.session-pill{
  display:inline-flex;
  padding:6px 10px;
  border-radius:999px;
  background:#eff6ff;
  border:1px solid #dbeafe;
  color:#1d4ed8;
  font-size:12px;
  font-weight:900;
  margin-bottom:8px;
}

.toc-head h4{
  margin:0;
  font-size:16px;
  line-height:1.45;
  letter-spacing:-.02em;
  word-break:keep-all;
}

.time-pill{
  flex:0 0 auto;
  display:inline-flex;
  padding:8px 10px;
  border-radius:12px;
  background:#f8fafc;
  border:1px solid var(--line);
  color:var(--text3);
  font-size:12px;
  font-weight:900;
}

.toc-body{
  padding:17px;
}

.toc-body dl{
  margin:0;
  display:grid;
  gap:12px;
}

.toc-body dt{
  margin:0 0 4px;
  color:var(--muted);
  font-size:12px;
  font-weight:900;
}

.toc-body dd{
  margin:0;
  color:var(--text2);
  font-size:13px;
  line-height:1.75;
  font-weight:700;
  word-break:keep-all;
}

.output-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:14px;
}

@media(max-width:1120px){
  .output-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

@media(max-width:640px){
  .output-grid{
    grid-template-columns:1fr;
  }
}

.output-card{
  padding:17px;
  background:linear-gradient(180deg,#ffffff,#fbfdff);
}

.output-icon{
  width:44px;
  height:44px;
  border-radius:16px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:10px;
  color:#fff;
  font-weight:900;
  background:linear-gradient(135deg,#1d4ed8,#4f46e5);
}

.output-card h4{
  margin:0 0 8px;
  font-size:15px;
}

.output-card p{
  margin:0;
  color:var(--text3);
  font-size:13px;
  line-height:1.75;
  word-break:keep-all;
}

.table-wrap{
  overflow:auto;
  border:1px solid var(--line);
  border-radius:22px;
  background:#fff;
  box-shadow:var(--shadow2);
}

table{
  width:100%;
  border-collapse:separate;
  border-spacing:0;
}

.report-table thead th{
  background:linear-gradient(180deg,#0f172a,#1e293b);
  color:#fff;
  text-align:left;
  padding:14px;
  font-size:12px;
  font-weight:900;
  letter-spacing:.05em;
  white-space:nowrap;
}

.report-table tbody td{
  padding:14px;
  border-bottom:1px solid var(--line);
  color:var(--text2);
  font-size:13px;
  line-height:1.75;
  vertical-align:top;
  background:#fff;
}

.report-table tbody tr:nth-child(even) td{
  background:#fcfdff;
}

.report-table tbody tr:last-child td{
  border-bottom:none;
}

.pill{
  display:inline-flex;
  align-items:center;
  padding:6px 10px;
  border-radius:999px;
  font-size:12px;
  font-weight:900;
  white-space:nowrap;
}

.pill.blue{background:#eff6ff;color:#1d4ed8;border:1px solid #dbeafe}
.pill.green{background:#ecfdf5;color:#059669;border:1px solid #d1fae5}
.pill.amber{background:#fff7ed;color:#d97706;border:1px solid #fed7aa}
.pill.purple{background:#f5f3ff;color:#6d28d9;border:1px solid #ddd6fe}

details{
  border:1px solid var(--line);
  background:#fff;
  border-radius:20px;
  overflow:hidden;
  box-shadow:var(--shadow2);
}

summary{
  list-style:none;
  cursor:pointer;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
  padding:16px 18px;
  color:var(--text);
  font-size:14px;
  font-weight:900;
}

summary::-webkit-details-marker{
  display:none;
}

.details-body{
  border-top:1px solid var(--line);
  padding:16px 18px 18px;
  color:var(--text2);
  font-size:14px;
  line-height:1.95;
  white-space:pre-wrap;
  word-break:keep-all;
}

.footer-note{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  flex-wrap:wrap;
  margin-top:14px;
  color:var(--muted);
  font-size:12px;
}

.toast-wrap{
  position:fixed;
  top:20px;
  right:20px;
  z-index:10000;
  display:flex;
  flex-direction:column;
  gap:10px;
}

.toast{
  padding:12px 14px;
  border-radius:14px;
  color:#fff;
  background:#0f172a;
  box-shadow:var(--shadow);
  font-size:13px;
  font-weight:800;
}

.toast.good{background:#065f46}
.toast.warn{background:#92400e}
.toast.bad{background:#991b1b}

.processing{
  position:fixed;
  inset:0;
  background:rgba(244,247,251,.84);
  backdrop-filter:blur(10px);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:9999;
}

.processing.show{
  display:flex;
}

.processing-card{
  width:min(620px,calc(100vw - 40px));
  padding:30px;
  border-radius:26px;
  background:#fff;
  border:1px solid var(--line);
  box-shadow:var(--shadow);
  text-align:center;
}

.loader{
  width:58px;
  height:58px;
  border-radius:50%;
  border:4px solid #dbeafe;
  border-top-color:#1d4ed8;
  animation:spin .8s linear infinite;
  margin:0 auto 18px;
}

@keyframes spin{
  to{transform:rotate(360deg)}
}

.processing-card h3{
  margin:0 0 8px;
  font-size:22px;
}

.processing-card p{
  margin:0 0 18px;
  color:var(--muted);
  font-size:14px;
  line-height:1.8;
}

.step-row{
  display:flex;
  justify-content:center;
  gap:10px;
  flex-wrap:wrap;
}

.step{
  padding:8px 12px;
  border-radius:999px;
  background:#f8fafc;
  border:1px solid var(--line);
  color:var(--muted);
  font-size:12px;
  font-weight:900;
}

.step.on{
  color:#1d4ed8;
  background:#eff6ff;
  border-color:#bfdbfe;
}

.step.done{
  color:#059669;
  background:#ecfdf5;
  border-color:#a7f3d0;
}

@media print{
  body{
    background:#fff;
  }

  .header,
  .memo-panel,
  .toolbar,
  .footer-note,
  .toast-wrap,
  .processing{
    display:none!important;
  }

  .app{
    max-width:none;
    padding:0;
  }

  .layout{
    grid-template-columns:1fr;
  }

  .panel{
    box-shadow:none;
    border:none;
  }

  .preview-wrap{
    padding:0;
  }

  .doc{
    box-shadow:none;
    border:none;
    border-radius:0;
  }

  .doc-cover,
  .doc-body{
    padding:24px;
  }

  .section,
  .metric,
  .section-box,
