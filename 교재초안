                ${renderSignal("운영 관점","차수별 피드백을 반영해 실습 예제와 안내 문구를 지속 보완하는 방식 권장","info")}
                ${renderSignal("보고 관점","자료 내 특정 임원 호칭은 사용하지 않고 객관적인 공유 및 보고 핵심사항으로 정리","good")}
              </div>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <h3>8. 다음 개발 액션</h3>
            <span class="section-tag">Next Actions</span>
          </div>

          <div class="section-box">
            ${renderList(insights.next,"다음 개발 액션이 별도로 입력되지 않았습니다.")}
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <h3>9. 공유 및 보고 핵심사항</h3>
            <span class="section-tag">Key Messages</span>
          </div>

          <div class="section-box">
            ${renderList(keyMessages,"공유 및 보고 핵심사항 없음")}
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <h3>10. 자유 메모 반영 내용</h3>
            <span class="section-tag">Appendix</span>
          </div>

          <details>
            <summary>
              <span>자동 분류 결과 및 원문 보기</span>
              <span style="color:#64748b">클릭하여 확인</span>
            </summary>
            <div class="details-body">[과정 방향]
${notes.direction.join("\n") || "없음"}

[필수 조건]
${notes.conditions.join("\n") || "없음"}

[목차 관련]
${notes.toc.join("\n") || "없음"}

[실습 관련]
${notes.practice.join("\n") || "없음"}

[역할 관련]
${notes.roles.join("\n") || "없음"}

[검토/리스크]
${notes.risks.join("\n") || "없음"}

[다음 액션]
${notes.next.join("\n") || "없음"}

[원문]
${esc(raw)}</div>
          </details>
        </section>

        <div class="footer-note" style="margin-top:18px">
          <span>작성일: ${todayStr()}</span>
          <span>본 문서는 자유 입력 메모를 기반으로 자동 정리된 교재 개요 및 목차안입니다.</span>
        </div>
      </section>
    </article>
  `;
}

function buildAll(){
  let raw = $("memoInput").value.trim();

  if(!raw){
    raw = "KICK OFF 장표 기준 기본안으로 교재 개요와 목차를 생성";
    toast("메모가 없어 기본 KICK OFF 기준으로 생성합니다.","warn");
  }

  $("processing").classList.add("show");
  setStep(1);

  setTimeout(()=>{
    const notes = categorizeNotes(raw);
    const flags = detectFlags(raw);
    setStep(2);

    setTimeout(()=>{
      const curriculum = buildCurriculum(flags);
      const roles = buildRoles();
      const insights = buildInsights(notes,flags);
      const html = buildReport(notes,flags,curriculum,roles,insights,raw);
      const summaryText = buildSummaryText(curriculum,insights);

      setStep(3);

      const mount = $("reportMount");
      mount.className = "";
      mount.innerHTML = html;

      lastReport = {
        raw,
        notes,
        flags,
        curriculum,
        roles,
        insights,
        html,
        summaryText,
        savedAt:new Date().toISOString()
      };

      localStorage.setItem(STORAGE_REPORT,JSON.stringify(lastReport));
      localStorage.setItem(STORAGE_DRAFT,$("memoInput").value);

      setTimeout(()=>{
        $("processing").classList.remove("show");
        toast("교재 개요·목차안 생성 완료","good");
      },260);
    },420);
  },360);
}

function setStep(step){
  ["step1","step2","step3"].forEach((id,idx)=>{
    const el = $(id);
    el.classList.remove("on","done");

    if(idx + 1 < step) el.classList.add("done");
    else if(idx + 1 === step) el.classList.add("on");
  });
}

